# ============================================
# AI Study Intelligence Platform - Environment
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://studyai:studyai_password@localhost:5432/studyai

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents_vectors

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=500

# Rate Limiting
RATE_LIMIT_PER_DAY=50

# CORS
FRONTEND_URL=http://localhost:3000
